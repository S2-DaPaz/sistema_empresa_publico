NODE_ENV=development
PORT=3001

# Security
JWT_SECRET=change-me-with-a-long-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
AUTH_CODE_SECRET=
AUTH_VERIFICATION_CODE_TTL_MINUTES=15
AUTH_PASSWORD_RESET_CODE_TTL_MINUTES=15
AUTH_RESEND_COOLDOWN_SECONDS=60
AUTH_MAX_CODE_ATTEMPTS=5
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_MINUTES=15
AUTH_LOGIN_BLOCK_MINUTES=15
AUTH_EMAIL_MAX_ATTEMPTS=5
AUTH_EMAIL_WINDOW_MINUTES=60
AUTH_EMAIL_BLOCK_MINUTES=60
AUTH_PASSWORD_MIN_LENGTH=8
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# Admin bootstrap
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=define-a-strong-password
AUTO_BOOTSTRAP_ADMIN=true

# Storage / serving
STATIC_DIR=
PUBLIC_BASE_URL=
PDF_CACHE_ENABLED=true
PDF_WARM_DEBOUNCE_MS=1500
PUBLIC_LINK_DEFAULT_DAYS=30
PDF_LOGO_PATH=
PDF_TEMPLATE_PATH=
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_ARGS=

# Database
DATABASE_URL=
DATABASE_SSL=false

# Email
EMAIL_PROVIDER=brevo
EMAIL_FROM_NAME=RV Sistema Empresa
EMAIL_FROM_ADDRESS=seu-remetente-verificado@seudominio.com
EMAIL_REPLY_TO=
BREVO_API_KEY=
BREVO_API_BASE_URL=https://api.brevo.com/v3
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Optional mobile update feed
MOBILE_APP_VERSION_CODE=0
MOBILE_APP_VERSION_NAME=
MOBILE_APP_APK_URL=
MOBILE_APP_NOTES=
MOBILE_APP_MANDATORY=false
