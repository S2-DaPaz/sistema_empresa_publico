# ══════════════════════════════════════════════════════════════════
# RV Sistema Empresa - Variáveis de Ambiente
# ══════════════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# STATIC_DIR=../web/dist
# PUBLIC_BASE_URL=https://seu-dominio.com
# ALLOWED_ORIGINS=https://seu-dominio.com,http://localhost:5173

# ── Banco de dados ────────────────────────────────────────────────
# Se DATABASE_URL estiver definida, usa PostgreSQL. Senão, SQLite local.
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Conexão DIRETA (sem pooler) — necessária para pg_dump.
# No Neon, a URL direta usa o endpoint sem "-pooler" no hostname.
# DATABASE_URL_DIRECT=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
# DATABASE_SSL=true

# ── Autenticação ──────────────────────────────────────────────────
# JWT_SECRET=gere-um-segredo-forte-aqui
# ACCESS_TOKEN_TTL=15m
# REFRESH_TOKEN_TTL_DAYS=30

# ── Admin bootstrap ──────────────────────────────────────────────
# ADMIN_NAME=Administrador
# ADMIN_EMAIL=admin@local
# ADMIN_PASSWORD=senha-forte
# AUTO_BOOTSTRAP_ADMIN=true

# ── Email ─────────────────────────────────────────────────────────
# EMAIL_PROVIDER=console
# EMAIL_FROM_NAME=RV Sistema Empresa
# EMAIL_FROM_ADDRESS=noreply@local.dev
# BREVO_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# ── Mobile update ─────────────────────────────────────────────────
# MOBILE_APP_VERSION_CODE=1
# MOBILE_APP_VERSION_NAME=1.0.0
# MOBILE_APP_APK_URL=
# MOBILE_APP_NOTES=
# MOBILE_APP_MANDATORY=false

# ── PDF / Puppeteer ───────────────────────────────────────────────
# PDF_CACHE_ENABLED=true
# PUPPETEER_EXECUTABLE_PATH=
# PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox

# ══════════════════════════════════════════════════════════════════
# Backup (usado pelo GitHub Actions e webhook)
# ══════════════════════════════════════════════════════════════════

# Segredo compartilhado entre o workflow do GitHub Actions e a API.
# Usado no header x-backup-secret para autenticar o webhook.
# BACKUP_WEBHOOK_SECRET=gere-um-segredo-forte-aqui

# ── Variáveis do GitHub Actions (configurar como Secrets/Vars) ───
# Estas variáveis são usadas APENAS no runner do GitHub Actions,
# NÃO precisam estar no .env da aplicação:
#
# Secrets:
#   DATABASE_URL_DIRECT          - URL de conexão direta ao Neon (sem pooler)
#   BACKUP_ENCRYPTION_PASSPHRASE - Senha para criptografia GPG AES-256
#   GDRIVE_FOLDER_ID             - ID da pasta no Google Drive
#   GDRIVE_SERVICE_ACCOUNT_JSON_B64 - JSON da service account em Base64
#   BACKUP_WEBHOOK_SECRET        - Mesmo valor acima (para o webhook)
#
# Variables (não secretas):
#   APP_BASE_URL                 - URL base da API (ex: https://seu-app.com)
#   BACKUP_RETENTION_COUNT       - Quantidade máxima de backups (padrão: 30)
